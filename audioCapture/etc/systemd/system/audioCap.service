[Unit]
Description=Capture and stream audio to the server running the recording program for AircraftAudioId
After=network.target

[Service]
Type=simple
User=jdn
Group=jdn
WorkingDirectory=/home/jdn/Code/AircraftAudioId/audioCapture
ExecStart=/home/jdn/Code/AircraftAudioId/aaiVenv/bin/python \
    /home/jdn/Code/AircraftAudioId/audioCapture/scripts/capture.py \
    --host 192.168.166.113
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
